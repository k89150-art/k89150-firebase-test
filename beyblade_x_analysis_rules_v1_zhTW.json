{
  "metadata": {
    "name": "Beyblade X 配置分析規則",
    "version": "1.0-alpha",
    "created": "2026-06-30",
    "language": "zh-TW",
    "status": "啟發式分析規則；用於網站初版自動分析，不代表官方勝率",
    "dependsOn": [
      "beyblade_x_database_v1_zhTW.json"
    ],
    "notes": [
      "規則以資料庫內的 roleTags、metaTier、confidence 為基礎進行加減分。",
      "原裝配置不作為強弱依據，只作為零件存在索引。",
      "分數用於排序與提示，不等於真實勝率。",
      "CX 結構需先判斷是三件式或四件式，四件式需拆成紋章鎖、金屬戰刃、超越戰刃、輔助戰刃。"
    ]
  },
  "inputSchema": {
    "normal": {
      "bladeIdOrName": "string",
      "ratchetCode": "string，例如 3-60、9-60、4-50",
      "bitCode": "string，例如 R、LR、B、H"
    },
    "cx": {
      "lockChipName": "string",
      "mainBladeName": "string|null，CX-01～CX-12 使用",
      "metalBladeName": "string|null，CX-13 後使用",
      "overBladeCode": "string|null，CX-13 後使用",
      "assistBladeCode": "string",
      "ratchetCode": "string",
      "bitCode": "string",
      "mode": "string|null，模式型 CX 如 極變 PO 可填 attack/balance/defense"
    }
  },
  "scoreDimensions": {
    "attack": "擊飛、Xtreme Finish、主動壓制能力",
    "stamina": "續航、末段、持久勝能力",
    "defense": "抗推、抗擊飛、抗攻擊能力",
    "balance": "攻防持久綜合與調整空間",
    "burstSafety": "不被爆裂與不被打固鎖的安全性",
    "control": "軌跡可控、發射容錯、自爆風險低",
    "metaConfidence": "資料信心與常見配置支持度"
  },
  "baseScores": {
    "metaTier": {
      "S": 3,
      "A": 2,
      "B": 1,
      "C": 0,
      "D": -1,
      "unknown": 0
    },
    "confidence": {
      "high": 2,
      "medium": 1,
      "low": 0,
      "unknown": 0
    }
  },
  "tagScoreMap": {
    "attack": {
      "attack": 2,
      "control": -1,
      "stamina": -1
    },
    "stamina": {
      "stamina": 2,
      "control": 1,
      "attack": -1
    },
    "defense": {
      "defense": 2,
      "burstSafety": 1,
      "attack": -1
    },
    "balance": {
      "balance": 2,
      "control": 1
    },
    "antiAttack": {
      "defense": 2,
      "control": 1,
      "stamina": -0.5
    },
    "lowHeight": {
      "burstSafety": 1,
      "control": 0.5
    },
    "leftSpin": {
      "balance": 1
    },
    "special": {
      "metaConfidence": -1
    },
    "highRisk": {
      "attack": 1,
      "control": -2,
      "burstSafety": -1
    },
    "modeChange": {
      "balance": 1,
      "control": -0.5
    }
  },
  "ratchetHeightRules": [
    {
      "id": "ratchet_50_attack",
      "when": {
        "heightMax": 55,
        "bladeTagsAny": [
          "attack"
        ]
      },
      "score": {
        "attack": 1.5,
        "burstSafety": 1,
        "control": -0.5
      },
      "message": "低身位固鎖能強化攻擊打點與降低被打固鎖機率，但需要注意刮地與控角。"
    },
    {
      "id": "ratchet_60_core",
      "when": {
        "height": 60
      },
      "score": {
        "burstSafety": 1,
        "control": 0.5
      },
      "message": "60 高度是目前最泛用的安全高度，通常較不容易被打固鎖。"
    },
    {
      "id": "ratchet_70_adjust",
      "when": {
        "height": 70
      },
      "score": {
        "balance": 0.5,
        "burstSafety": -0.5
      },
      "message": "70 高度可調整上蓋打點，但若沒有明確目的，安全性通常不如 60。"
    },
    {
      "id": "ratchet_80_risky",
      "when": {
        "heightMin": 80
      },
      "score": {
        "burstSafety": -2,
        "control": -1
      },
      "message": "80 / 85 高度容易暴露固鎖與提高重心，除非有明確高身位策略，否則需扣分。"
    },
    {
      "id": "ratchet_9_burst_safe",
      "when": {
        "codeStartsWith": "9-"
      },
      "score": {
        "burstSafety": 1.5,
        "stamina": 0.5
      },
      "message": "9 系固鎖通常有較好的爆裂安全性，適合持久、防守與穩定配置。"
    },
    {
      "id": "ratchet_1_attack_bias",
      "when": {
        "codeStartsWith": "1-"
      },
      "score": {
        "attack": 1,
        "stamina": -0.5,
        "control": -0.5
      },
      "message": "1 系固鎖偏向攻擊對位，但穩定與持久通常較差。"
    },
    {
      "id": "ratchet_5_stable",
      "when": {
        "codeStartsWith": "5-"
      },
      "score": {
        "stamina": 0.8,
        "defense": 0.5,
        "control": 0.5
      },
      "message": "5 系固鎖通常較穩，適合持久、防守與平衡配置。"
    },
    {
      "id": "ratchet_7_heavy_defense",
      "when": {
        "codeStartsWith": "7-"
      },
      "score": {
        "defense": 1,
        "stamina": 0.5
      },
      "message": "7 系多點分布適合防守與持久，但需注意體積與刮地。"
    }
  ],
  "bitRoleRules": [
    {
      "id": "bit_r_lr_attack_core",
      "bitCodes": [
        "R",
        "LR"
      ],
      "score": {
        "attack": 2,
        "control": 1,
        "metaConfidence": 1
      },
      "message": "R / LR 是高信心攻擊核心，R 偏可控，LR 偏低身位攻擊。"
    },
    {
      "id": "bit_gf_a_v_burst",
      "bitCodes": [
        "GF",
        "A",
        "V"
      ],
      "score": {
        "attack": 2.5,
        "control": -1.5,
        "stamina": -1
      },
      "message": "GF / A / V 爆發高，但自爆與耗耐久風險也高。"
    },
    {
      "id": "bit_b_pure_stamina",
      "bitCodes": [
        "B"
      ],
      "score": {
        "stamina": 2.5,
        "defense": -0.5,
        "burstSafety": -0.5
      },
      "message": "B 是純持久核心，但抗推與爆抗需要其他零件補強。"
    },
    {
      "id": "bit_o_db_stable_stamina",
      "bitCodes": [
        "O",
        "DB"
      ],
      "score": {
        "stamina": 2,
        "control": 1
      },
      "message": "O / DB 偏穩定持久，適合續航與留中。"
    },
    {
      "id": "bit_h_anti_attack",
      "bitCodes": [
        "H"
      ],
      "score": {
        "defense": 2.5,
        "control": 1,
        "stamina": -0.5,
        "metaConfidence": 1
      },
      "message": "H 更像 anti-attack 核心，可讓持久或重型上蓋更能抗攻擊。"
    },
    {
      "id": "bit_e_left_spin",
      "bitCodes": [
        "E"
      ],
      "score": {
        "stamina": 1.5,
        "balance": 1,
        "metaConfidence": 1
      },
      "message": "E 的主要價值在左迴旋末段與反旋對局，非所有右迴旋配置都適合。"
    },
    {
      "id": "bit_l_mixed",
      "bitCodes": [
        "L"
      ],
      "score": {
        "attack": 1.3,
        "stamina": 1.3,
        "balance": 1,
        "control": -0.5
      },
      "message": "L 是攻擊持久混合，適合重型平衡攻擊路線。"
    },
    {
      "id": "bit_p_technical",
      "bitCodes": [
        "P"
      ],
      "score": {
        "balance": 2,
        "control": 0.5
      },
      "message": "P 是技術型平衡軸心，發射角度會決定它偏攻擊或偏留中。"
    },
    {
      "id": "bit_lo_un_low_stamina",
      "bitCodes": [
        "LO",
        "UN"
      ],
      "score": {
        "stamina": 1.5,
        "burstSafety": 1,
        "defense": 0.5
      },
      "message": "LO / UN 可做低身位持久或安全持久，但抗強攻仍需上蓋支撐。"
    },
    {
      "id": "bit_q_ra_j_risky",
      "bitCodes": [
        "Q",
        "RA",
        "J"
      ],
      "score": {
        "attack": 1.5,
        "control": -2,
        "stamina": -1,
        "metaConfidence": -1
      },
      "message": "Q / RA / J 屬奇襲或高風險攻擊，適合搏分，不適合穩定保底。"
    },
    {
      "id": "bit_op_tr_integrated",
      "bitCodes": [
        "Op",
        "Tr"
      ],
      "score": {
        "metaConfidence": -1
      },
      "message": "Op / Tr 是固鎖一體式軸心，必須獨立評估，不能直接和一般 Bit 排名。"
    }
  ],
  "synergyRules": [
    {
      "id": "attack_blade_attack_bit",
      "when": {
        "bladeTagsAny": [
          "attack"
        ],
        "bitCodes": [
          "R",
          "LR",
          "GF",
          "A",
          "V",
          "F",
          "LF",
          "I"
        ]
      },
      "score": {
        "attack": 2,
        "metaConfidence": 0.5
      },
      "message": "攻擊上蓋搭攻擊軸心，勝利方式明確。"
    },
    {
      "id": "attack_blade_stamina_bit_conflict",
      "when": {
        "bladeTagsAny": [
          "attack"
        ],
        "bitCodes": [
          "B",
          "O",
          "DB",
          "N",
          "MN",
          "W"
        ]
      },
      "score": {
        "attack": -1.5,
        "balance": -0.5
      },
      "warning": "攻擊上蓋搭純持久 / 定點軸心，路線可能互相抵消。"
    },
    {
      "id": "stamina_blade_stamina_bit",
      "when": {
        "bladeTagsAny": [
          "stamina"
        ],
        "bitCodes": [
          "B",
          "O",
          "DB",
          "LO",
          "FB",
          "W",
          "WW",
          "UN"
        ]
      },
      "score": {
        "stamina": 2,
        "control": 1
      },
      "message": "持久上蓋搭持久軸心，路線清楚。"
    },
    {
      "id": "stamina_blade_over_aggressive",
      "when": {
        "bladeTagsAny": [
          "stamina"
        ],
        "bitCodes": [
          "GF",
          "A",
          "Q",
          "RA"
        ]
      },
      "score": {
        "stamina": -2,
        "control": -1
      },
      "warning": "持久上蓋搭過度暴衝軸心，可能浪費續航優勢。"
    },
    {
      "id": "defense_blade_h_wb",
      "when": {
        "bladeTagsAny": [
          "defense",
          "antiAttack"
        ],
        "bitCodes": [
          "H",
          "WB",
          "BS",
          "UN"
        ]
      },
      "score": {
        "defense": 2,
        "control": 0.5
      },
      "message": "防守 / anti-attack 上蓋搭防守軸心，相性良好。"
    },
    {
      "id": "left_spin_e",
      "when": {
        "bladeTagsAny": [
          "leftSpin"
        ],
        "bitCodes": [
          "E"
        ]
      },
      "score": {
        "stamina": 2,
        "balance": 1,
        "metaConfidence": 1
      },
      "message": "左迴旋搭 E 可強化反旋末段，是高價值方向。"
    },
    {
      "id": "left_spin_no_e",
      "when": {
        "bladeTagsAny": [
          "leftSpin"
        ],
        "bitCodesNot": [
          "E",
          "L",
          "LR",
          "R"
        ]
      },
      "score": {
        "metaConfidence": -0.5
      },
      "message": "左迴旋若不是走 E 末段或攻擊路線，需確認勝利方式。"
    },
    {
      "id": "low_ratchet_low_bit",
      "when": {
        "ratchetHeightMax": 55,
        "bitCodes": [
          "LR",
          "LF",
          "LO",
          "UN",
          "I"
        ]
      },
      "score": {
        "burstSafety": 1.2,
        "attack": 0.8
      },
      "message": "低固鎖搭低身位軸心，可強化低打點與防爆，但要檢查刮地。"
    },
    {
      "id": "high_ratchet_needle_bad",
      "when": {
        "ratchetHeightMin": 80,
        "bitCodes": [
          "N",
          "MN",
          "HN",
          "UN"
        ]
      },
      "score": {
        "defense": -1,
        "burstSafety": -1.5,
        "control": -1
      },
      "warning": "高身位固鎖搭針型軸心容易被強攻推出或打固鎖。"
    }
  ],
  "cxRules": [
    {
      "id": "cx_assist_heavy",
      "assistCodes": [
        "H"
      ],
      "score": {
        "attack": 1,
        "defense": 1,
        "burstSafety": 0.5,
        "metaConfidence": 1
      },
      "message": "Heavy 輔助戰刃重、低、不太遮主戰刃打點，是 CX 高價值核心。"
    },
    {
      "id": "cx_assist_b_w_defense",
      "assistCodes": [
        "B",
        "W"
      ],
      "score": {
        "defense": 1.5,
        "stamina": 1,
        "control": 0.5
      },
      "message": "Bumper / Wheel 適合防守、持久與化解攻擊。"
    },
    {
      "id": "cx_assist_e_z_anti_low",
      "assistCodes": [
        "E",
        "Z"
      ],
      "score": {
        "defense": 1.5,
        "balance": 0.5
      },
      "message": "Erase / Zillion 有 anti-attack、抗下方攻擊或干擾低身位對手的價值。"
    },
    {
      "id": "cx_assist_k_attack_risk",
      "assistCodes": [
        "K"
      ],
      "score": {
        "attack": 1.5,
        "control": -0.8
      },
      "message": "Knuckle 可強化集中打點攻擊，但反作用與自耗風險較高。"
    },
    {
      "id": "cx_assist_free_odd_special",
      "assistCodes": [
        "F",
        "O",
        "D"
      ],
      "score": {
        "metaConfidence": -0.5
      },
      "message": "Free / Odd / Dual 偏特化或資料不足，需看具體模式與實測。"
    },
    {
      "id": "cx_metal_strike_attack",
      "metalNames": [
        "閃擊"
      ],
      "score": {
        "attack": 2,
        "stamina": -0.5
      },
      "message": "閃擊是低身位一擊攻擊核心，適合搭低固鎖與攻擊軸心。"
    },
    {
      "id": "cx_metal_rage_anti",
      "metalNames": [
        "狂怒"
      ],
      "score": {
        "defense": 1.5,
        "balance": 1
      },
      "message": "狂怒較像反攻 / anti-attack，不宜只當純攻擊看。"
    },
    {
      "id": "cx_metal_whip_stamina",
      "metalNames": [
        "鞭擊"
      ],
      "score": {
        "stamina": 1.5,
        "balance": 0.5
      },
      "message": "鞭擊目前偏持久 / 干擾 / 外重心路線，資料仍需累積。"
    },
    {
      "id": "cx_over_flow_low_interference",
      "overCodes": [
        "F"
      ],
      "score": {
        "control": 0.8,
        "balance": 0.5
      },
      "message": "Flow 超越戰刃偏低干涉與配重調整，不應誤判成強攻零件。"
    },
    {
      "id": "cx_mode_peak_odd",
      "overCodes": [
        "P"
      ],
      "assistCodes": [
        "O"
      ],
      "score": {
        "balance": 1,
        "control": -0.5
      },
      "message": "極變 PO 屬模式型，必須標明攻擊 / 平衡 / 防禦裝配方向。"
    }
  ],
  "outcomeClassifier": {
    "primaryRoleByHighestScore": {
      "attack": "攻擊 / 擊飛型",
      "stamina": "持久 / 續航型",
      "defense": "防禦 / 抗攻擊型",
      "balance": "平衡 / 反打型"
    },
    "secondaryFlags": [
      {
        "id": "high_burst_safety",
        "dimension": "burstSafety",
        "min": 4,
        "label": "爆裂安全性佳"
      },
      {
        "id": "low_control",
        "dimension": "control",
        "max": -1,
        "label": "控制風險高"
      },
      {
        "id": "low_confidence",
        "dimension": "metaConfidence",
        "max": 0,
        "label": "資料待驗證"
      },
      {
        "id": "high_attack_low_control",
        "conditions": {
          "attackMin": 5,
          "controlMax": 0
        },
        "label": "高爆發高風險"
      },
      {
        "id": "stamina_low_defense",
        "conditions": {
          "staminaMin": 5,
          "defenseMax": 1
        },
        "label": "純持久但怕強攻"
      }
    ]
  },
  "recommendationRules": [
    {
      "id": "too_aggressive",
      "whenFlags": [
        "控制風險高"
      ],
      "suggest": [
        "若自爆或出界太多，優先把 GF / A / V / Q 調成 R 或 LR。",
        "若仍想保留攻擊，可改用 3-60 或 4-50 提升穩定。"
      ]
    },
    {
      "id": "too_high",
      "whenMessagesContain": [
        "80 / 85 高度"
      ],
      "suggest": [
        "若沒有高身位目的，優先改 9-60、5-60、3-60 或 4-50。"
      ]
    },
    {
      "id": "stamina_gets_ko",
      "whenFlags": [
        "純持久但怕強攻"
      ],
      "suggest": [
        "若容易被強攻推出，可從 B / O / DB 改測 H、WB、LO 或 UN。",
        "Ratchet 可優先測 9-60、5-60、7-55。"
      ]
    },
    {
      "id": "attack_conflict",
      "whenWarningsContain": [
        "互相抵消"
      ],
      "suggest": [
        "先決定要走攻擊或持久；攻擊路線優先 R / LR / GF，持久路線優先 B / O / DB / LO。"
      ]
    },
    {
      "id": "cx_attack_tune",
      "whenMessagesContain": [
        "閃擊"
      ],
      "suggest": [
        "閃擊類一擊攻擊可優先測 1-50 / 4-50 搭 I / R / LR。",
        "若反作用太大，先把 I 或 GF 改成 R / LR。"
      ]
    },
    {
      "id": "cx_heavy_tune",
      "whenMessagesContain": [
        "Heavy"
      ],
      "suggest": [
        "Heavy 可作 CX 泛用補強；若覺得太鈍，可改測 J / A / K 強化主動攻擊，或 W / B 強化防守。"
      ]
    }
  ],
  "outputTemplate": {
    "summary": "一句話定位",
    "scores": "七維分數",
    "primaryRole": "主要定位",
    "strengths": "優點列表",
    "weaknesses": "缺點列表",
    "warnings": "風險提醒",
    "recommendations": "改裝建議",
    "deckRole": "3G / 5G 建議位置",
    "confidence": "高 / 中 / 待驗證"
  }
}